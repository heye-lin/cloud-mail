# Forward inbound MIME requests to the Node API.
# Replace the hostname and upstream address to match your deployment.

mail-api.example.com {
    request_body {
        max_size 50MB
    }

    reverse_proxy /api/webhooks/inbound-email 127.0.0.1:8787 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        flush_interval -1
    }
}
